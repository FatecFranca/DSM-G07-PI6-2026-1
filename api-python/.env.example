# ========================================
# CONFIGURAÇÃO DA API JAVA
# ========================================
# URL do servidor da API Java
# Desenvolvimento local:
API_URL=http://localhost:8080

# Produção (Servidor Google Cloud):
# API_URL=http://34.24.9.134:8080

# ========================================
# CONFIGURAÇÃO JWT
# ========================================
# IMPORTANTE: Esta chave DEVE ser IDÊNTICA à JWT_SECRET da API Java
# para que os tokens possam ser validados corretamente
# IMPORTANTE: Altere esta chave em produção para um valor único e seguro
# Recomendação: Use uma string aleatória de pelo menos 256 bits
JWT_SECRET=petdex-secret-key-change-in-production

# ========================================
# CONFIGURAÇÃO DO SERVIDOR (PRODUÇÃO)
# ========================================
# IP Público: 34.24.9.134
# Porta: 8083
